# paper_trader environment configuration
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# PostgreSQL DSN for the main (production / development) database.
# Format: postgresql+psycopg2://user:password@host:port/dbname
PAPER_TRADER_DATABASE_URL=postgresql+psycopg2://postgres:changeme@localhost:5432/paper_trader

# API key required on every request to the paper_trader service endpoints.
# Set the same value in X-API-Key header when calling the API.
PAPER_TRADER_SERVICE_API_KEY=change-me-before-use

# ---------------------------------------------------------------------------
# Optional — portfolio seeding defaults
# ---------------------------------------------------------------------------

# Starting capital in dollars. Used by scripts/seed.py when --initial-capital
# is not passed on the command line. Default: 10000.00
# PAPER_TRADER_INITIAL_CAPITAL=10000.00

# ---------------------------------------------------------------------------
# Optional — risk engine defaults
# ---------------------------------------------------------------------------

# Maximum number of concurrent open positions. Default: 5
# PAPER_TRADER_MAX_POSITIONS=5

# Maximum portfolio fraction in a single position (e.g. 0.20 = 20%). Default: 0.20
# PAPER_TRADER_MAX_CONCENTRATION_PCT=0.20

# Minimum cash reserve fraction (e.g. 0.10 = 10%). Default: 0.10
# PAPER_TRADER_MIN_CASH_PCT=0.10

# Maximum fraction of portfolio deployed in new buys per day. Default: 0.40
# PAPER_TRADER_MAX_DAILY_NEW_EXPOSURE_PCT=0.40

# Minimum signal confidence to approve a BUY (e.g. 0.55 = 55%). Default: 0.55
# PAPER_TRADER_CONFIDENCE_THRESHOLD=0.55

# Minimum dollar size of a single approved order. Default: 50.00
# PAPER_TRADER_MIN_ORDER_NOTIONAL=50.00

# Hours after a SELL during which re-buying the same ticker is blocked. Default: 48
# PAPER_TRADER_COOLDOWN_HOURS=48

# Allow adding to an existing position (averaging down). Default: false
# PAPER_TRADER_ALLOW_AVERAGING_DOWN=false

# ---------------------------------------------------------------------------
# Optional — benchmark and logging
# ---------------------------------------------------------------------------

# Ticker used for benchmark comparison. Default: SPY
# PAPER_TRADER_BENCHMARK_TICKER=SPY

# Python logging level name. Default: INFO
# PAPER_TRADER_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Test suite only
# ---------------------------------------------------------------------------

# Separate PostgreSQL DSN for the test database. DB tests are automatically
# skipped when this is not set. The test suite creates and drops all tables
# on each run — use a dedicated database, not the main one.
# PAPER_TRADER_TEST_DATABASE_URL=postgresql+psycopg2://postgres:changeme@localhost:5432/paper_trader_test
